#!/usr/bin/env sh
set -e
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

echo "== Bringing up Postgres in Docker =="
cd "$ROOT" && docker compose up -d

echo "== Waiting for Postgres =="
until docker compose exec -T postgres pg_isready -U wallgarden >/dev/null 2>&1; do
  sleep 1
done
echo "Postgres ready."

echo "== Daemon Python deps =="
cd "$ROOT/daemon" && uv sync --extra dev

echo "== Rails =="
cd "$ROOT/web" && bin/setup

echo
echo "Done. Start the full dev stack with: foreman start -f Procfile.dev"
