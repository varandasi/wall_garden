# Backend selection: 'simulator' for dev on macOS, 'pi' for real hardware
WALLGARDEN_BACKEND=simulator

# Simulator knobs (only used when WALLGARDEN_BACKEND=simulator)
WALLGARDEN_SIM_SPEED=1                    # 1 = real time, 60 = 60x faster
WALLGARDEN_SIM_CONTROL=daemon/simulator/control.json   # failure injection file (hot-reloaded)

# Postgres (shared by daemon + Rails)
DATABASE_URL=postgres://wallgarden:wallgarden@localhost:5433/wallgarden_development

# Anthropic via ruby_llm
ANTHROPIC_API_KEY=
MONTHLY_LLM_COST_CAP_USD=5

# ntfy notifications
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC_CRITICAL=wallgarden-CHANGE-ME-CRITICAL
NTFY_TOPIC_DIGEST=wallgarden-CHANGE-ME-DIGEST

# Email (digests + critical alerts)
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USER_NAME=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=wallgarden@example.com

# Photo storage (daemon writes, Rails reads)
PHOTOS_DIR=/var/lib/wallgarden/photos     # macOS dev: ./tmp/photos
