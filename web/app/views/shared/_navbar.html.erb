<nav class="navbar navbar-expand-lg navbar-dark bg-success-emphasis sticky-top">
  <div class="container-fluid">
    <%= link_to root_path, class: "navbar-brand fw-semibold" do %>
      <i class="bi bi-flower2 me-1" aria-hidden="true"></i>
      <%= t(:app_name) %>
    <% end %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-main" aria-controls="navbar-main" aria-expanded="false">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbar-main">
      <% if user_signed_in? %>
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><%= link_to t('navbar.dashboard'), root_path, class: "nav-link #{'active' if controller_name == 'dashboard'}" %></li>
          <li class="nav-item"><%= link_to t('navbar.zones'), zones_path, class: "nav-link #{'active' if controller_name == 'zones'}" %></li>
          <li class="nav-item"><%= link_to t('navbar.plants'), plant_profiles_path, class: "nav-link #{'active' if controller_name == 'plant_profiles'}" %></li>
          <li class="nav-item"><%= link_to t('navbar.alerts'), alerts_path, class: "nav-link #{'active' if controller_name == 'alerts'}" %></li>
          <li class="nav-item"><%= link_to t('navbar.photos'), photos_path, class: "nav-link #{'active' if controller_name == 'photos'}" %></li>
          <li class="nav-item"><%= link_to t('navbar.chat'), chat_path, class: "nav-link #{'active' if controller_name == 'chats'}" %></li>
          <li class="nav-item"><%= link_to t('navbar.jobs'), '/jobs', class: "nav-link" %></li>
        </ul>
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link text-light-emphasis"><%= current_user.email %></span>
          </li>
          <li class="nav-item">
            <%= button_to t('navbar.sign_out'), destroy_user_session_path, method: :delete, class: "btn btn-link nav-link" %>
          </li>
        </ul>
      <% end %>
    </div>
  </div>
