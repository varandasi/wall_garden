# syntax=docker/dockerfile:1
# Generated by `dockerfile-rails` (Rails 8.1 default), tightened for arm64 Pi 5.

ARG RUBY_VERSION=3.4.7
FROM ruby:$RUBY_VERSION-slim AS base

WORKDIR /rails

ENV RAILS_ENV=production \
    BUNDLE_DEPLOYMENT=1 \
    BUNDLE_PATH=/usr/local/bundle \
    BUNDLE_WITHOUT="development:test"

FROM base AS build

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential libpq-dev libyaml-dev libjemalloc2 git pkg-config curl && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

COPY Gemfile Gemfile.lock ./
RUN bundle install --jobs 4 && \
    rm -rf ~/.bundle/ "${BUNDLE_PATH}/ruby/*/cache" "${BUNDLE_PATH}/ruby/*/bundler/gems/*/.git"

COPY . .

RUN bundle exec bootsnap precompile app/ lib/ config/

# Precompile assets without secrets (keys must not exist at build time).
RUN SECRET_KEY_BASE_DUMMY=1 ./bin/rails assets:precompile

FROM base AS final

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      curl libpq5 libjemalloc2 postgresql-client && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/* && \
    groupadd -r rails && useradd -r -g rails -d /rails rails && \
    chown -R rails:rails /rails

COPY --from=build /usr/local/bundle /usr/local/bundle
COPY --from=build --chown=rails:rails /rails /rails

USER rails

ENV LD_PRELOAD=libjemalloc.so.2

EXPOSE 3100
ENTRYPOINT ["./bin/thrust"]
CMD ["./bin/rails", "server"]
