#!/usr/bin/env ruby
require 'fileutils'

APP_ROOT = File.expand_path('..', __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  puts "== Installing dependencies =="
  system! 'gem install bundler --conservative'
  system('bundle check') || system!('bundle install')

  puts "\n== Preparing database =="
  system! 'bin/rails db:prepare'

  puts "\n== Installing SolidQueue/SolidCable migrations (idempotent) =="
  system!('bin/rails solid_queue:install') unless File.exist?('db/queue_schema.rb')
  system!('bin/rails solid_cable:install') unless File.exist?('db/cable_schema.rb')
  system! 'bin/rails db:migrate'

  puts "\n== Seeding =="
  system! 'bin/rails db:seed'

  puts "\n== Removing old logs and tempfiles =="
  system! 'bin/rails log:clear tmp:clear'

  puts "\n== Done. Start the dev stack with `bin/dev`. =="
end
